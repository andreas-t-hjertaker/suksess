# =============================================================================
# Suksess — Miljøvariabler (#149)
# =============================================================================
# Kopier denne filen til .env.local og fyll inn verdier.
# NB: NEXT_PUBLIC_*-variabler er synlige i nettleseren — ikke legg inn hemmeligheter!
# Hemmeligheter (API-nøkler, Stripe secret) settes i Firebase Secret Manager.
#
# Validering: src/lib/env.ts (Zod) sjekker at påkrevde variabler er satt.
# =============================================================================

# ---------------------------------------------------------------------------
# Firebase (PÅKREVD) — hentes fra Firebase Console → Prosjektinnstillinger
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.europe-west1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# ---------------------------------------------------------------------------
# Firebase App Check (valgfri) — reCAPTCHA Enterprise
# Hent fra: Google Cloud Console → reCAPTCHA Enterprise → Nøkler
# ---------------------------------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=

# ---------------------------------------------------------------------------
# Feide OIDC (valgfri)
# OIDC-klient opprettes på: kunde.feide.no
# FEIDE_CLIENT_ID og FEIDE_CLIENT_SECRET settes i Firebase Secret Manager
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FEIDE_PROVIDER_ID=oidc.feide

# ---------------------------------------------------------------------------
# Weaviate vektordatabase (valgfri)
# Hent fra: Weaviate Cloud Console → Cluster Details
# WEAVIATE_API_KEY settes i Firebase Secret Manager
# ---------------------------------------------------------------------------
NEXT_PUBLIC_WEAVIATE_URL=
NEXT_PUBLIC_WEAVIATE_PROXY=/api/search

# ---------------------------------------------------------------------------
# Stripe betalingsintegrasjon (valgfri — for B2B)
# STRIPE_SECRET_KEY og STRIPE_WEBHOOK_SECRET → Firebase Secret Manager
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_SKOLE=

# ---------------------------------------------------------------------------
# Cloud Functions base URL (valgfri)
# Lokal utvikling: http://127.0.0.1:5001/suksess-842ed/europe-west1
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CF_BASE_URL=https://europe-west1-suksess-842ed.cloudfunctions.net

# ---------------------------------------------------------------------------
# Firebase Emulator Suite (kun lokal utvikling)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_USE_EMULATOR=true
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# =============================================================================
# CLOUD FUNCTIONS SECRETS (settes via Firebase Secret Manager, IKKE her)
# =============================================================================
# firebase functions:secrets:set STRIPE_SECRET_KEY
# firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
# firebase functions:secrets:set STRIPE_PRICE_B2B_SCHOOL
# firebase functions:secrets:set STRIPE_PRICE_B2B_MUNICIPALITY
# firebase functions:secrets:set RESEND_API_KEY
# firebase functions:secrets:set SMTP_HOST
# firebase functions:secrets:set SMTP_PORT
# firebase functions:secrets:set SMTP_USER
# firebase functions:secrets:set SMTP_PASS
# firebase functions:secrets:set NAV_STILLINGER_TOKEN
# firebase functions:secrets:set NAV_API_TOKEN

# =============================================================================
# Suksess — Miljøvariabler (Issue #1: Prosjektoppsett)
# =============================================================================
# Kopier denne filen til .env.local og fyll inn verdier.
# NB: NEXT_PUBLIC_*-variabler er synlige i nettleseren — ikke legg inn hemmeligheter!
# Hemmeligheter (API-nøkler, stripe secret key) settes i Firebase Secret Manager.

# Firebase (prosjektidentifikatorer — hentes fra Firebase Console → Prosjektinnstillinger)
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.europe-west1.firebasedatabase.app
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Firebase App Check (reCAPTCHA Enterprise)
# Hent fra: Google Cloud Console → reCAPTCHA Enterprise → Nøkler
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY_HERE

# Feide OIDC
# OIDC-klient opprettes på: kunde.feide.no
# FEIDE_CLIENT_ID og FEIDE_CLIENT_SECRET settes i Firebase Secret Manager
NEXT_PUBLIC_FEIDE_PROVIDER_ID=oidc.feide

# Weaviate (vektordatabase — EU for GDPR)
# Hent fra: Weaviate Cloud Console → Cluster Details
# WEAVIATE_API_KEY settes i Firebase Secret Manager
NEXT_PUBLIC_WEAVIATE_URL=https://YOUR_CLUSTER_ID.weaviate.network
NEXT_PUBLIC_WEAVIATE_PROXY=/api/search

# Cloud Functions URL
# For lokal utvikling med emulator: http://127.0.0.1:5001/suksess-842ed/europe-west1
NEXT_PUBLIC_FUNCTIONS_URL=https://europe-west1-suksess-842ed.cloudfunctions.net

# Stripe (kun publishable key og price IDs er offentlige)
# STRIPE_SECRET_KEY og STRIPE_WEBHOOK_SECRET settes i Firebase Secret Manager
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_PUBLISHABLE_KEY
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_REPLACE_WITH_PRO_PRICE_ID
NEXT_PUBLIC_STRIPE_PRICE_SCHOOL=price_REPLACE_WITH_SCHOOL_PRICE_ID

# Lokal utvikling med Firebase Emulator Suite
# Sett NEXT_PUBLIC_USE_EMULATOR=true for å bruke emulatorer
NEXT_PUBLIC_USE_EMULATOR=false
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# NAV API (settes i Firebase Secret Manager for Cloud Functions)
# NAV_STILLINGER_TOKEN — fra: https://github.com/navikt/pam-stilling-feed
# NAV_API_TOKEN — fra: NAV Arbeidsplassen utviklermiljø

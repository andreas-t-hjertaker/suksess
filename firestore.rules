rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------------
    // Hjelpefunksjoner
    // ---------------------------------------------------------------------------

    /** Er brukeren innlogget? */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** Er brukeren eier av dokumentet? */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /** Har brukeren admin-rolle (custom claim)? */
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.get("role", "") in ["admin", "superadmin"];
    }

    /** Har brukeren superadmin-rolle? */
    function isSuperAdmin() {
      return isAuthenticated() &&
        request.auth.token.get("role", "") == "superadmin";
    }

    /** Henter tenantId fra brukerens custom claim */
    function userTenantId() {
      return request.auth.token.get("tenantId", null);
    }

    /** Er brukeren en del av samme tenant? */
    function isSameTenant(tenantId) {
      return isAuthenticated() && userTenantId() == tenantId;
    }

    /** Er brukeren rådgiver eller admin? */
    function isCounselorOrAdmin() {
      return isAuthenticated() &&
        request.auth.token.get("role", "") in ["counselor", "admin", "superadmin"];
    }

    // ---------------------------------------------------------------------------
    // users/{userId}
    // ---------------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isOwner(userId) || isCounselorOrAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isSuperAdmin();

      // Personlighetsprofil (subcollection)
      match /personalityProfile/{docId} {
        allow read, write: if isOwner(userId);
        allow read: if isCounselorOrAdmin();
      }

      // Testresultater (subcollection)
      match /testResults/{resultId} {
        allow read, write: if isOwner(userId);
        allow read: if isCounselorOrAdmin();
      }

      // Karakterer (subcollection)
      match /grades/{gradeId} {
        allow read, write: if isOwner(userId);
        allow read: if isCounselorOrAdmin();
      }

      // Samtalehistorikk med AI (subcollection)
      match /conversations/{convId} {
        allow read, write: if isOwner(userId);
      }

      // Varsler (subcollection)
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) || isCounselorOrAdmin();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // Gamification (subcollection) — XP og achievements
      match /gamification/{docId} {
        allow read: if isOwner(userId) || isCounselorOrAdmin();
        allow write: if isOwner(userId); // klient-side XP-oppdatering
      }

      // Achievements (subcollection)
      match /achievements/{achievId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // AI-innholdscache (subcollection)
      match /aiCache/{cacheKey} {
        allow read, write: if isOwner(userId);
      }

      // Dokumenter og testresultat-arkiv (subcollection)
      match /documents/{docId} {
        allow read, write: if isOwner(userId);
        allow read: if isCounselorOrAdmin();
      }

      // Søknader (subcollection)
      match /soknader/{soknadId} {
        allow read, write: if isOwner(userId);
        allow read: if isCounselorOrAdmin();
      }

      // Studier (subcollection) — emner og eksamenssjekkliste
      match /studier/{docId} {
        allow read, write: if isOwner(userId);
      }

      // CV-utkast (subcollection)
      match /cv/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Jobbmatch-favoritter (subcollection)
      match /jobbmatch/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ---------------------------------------------------------------------------
    // profiles/{userId} — profilens hoveddokument
    // ---------------------------------------------------------------------------

    match /profiles/{userId} {
      allow read: if isOwner(userId) || isCounselorOrAdmin();
      allow write: if isOwner(userId);
    }

    // ---------------------------------------------------------------------------
    // tenants/{tenantId}
    // ---------------------------------------------------------------------------

    match /tenants/{tenantId} {
      allow read: if isSameTenant(tenantId) || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ---------------------------------------------------------------------------
    // careerPaths/{pathId} — delte karriereveier (read-only for brukere)
    // ---------------------------------------------------------------------------

    match /careerPaths/{pathId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // studyPrograms/{programId}
    // ---------------------------------------------------------------------------

    match /studyPrograms/{programId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // programfag/{fagId}
    // ---------------------------------------------------------------------------

    match /programfag/{fagId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // generatedContent/{contentId} — AI-generert innhold
    // ---------------------------------------------------------------------------

    match /generatedContent/{contentId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         resource.data.userId == null);
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // subscriptions/{userId}
    // ---------------------------------------------------------------------------

    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // apiKeys/{keyId} — flat samling, userId-felt brukes til filtrering
    // NB: apiKeys brukes kun via Cloud Functions (admin SDK) — ingen klient-skriving
    // ---------------------------------------------------------------------------

    match /apiKeys/{keyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // featureFlags/{flagId}
    // ---------------------------------------------------------------------------

    match /featureFlags/{flagId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // notes/{noteId}
    // ---------------------------------------------------------------------------

    match /notes/{noteId} {
      allow read, write: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------------------
    // Hjelpefunksjoner
    // ---------------------------------------------------------------------------

    /** Er brukeren innlogget? */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** Er brukeren eier av dokumentet? */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /** Har brukeren admin-rolle (custom claim)? */
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.get("role", "") in ["admin", "superadmin"];
    }

    /** Har brukeren superadmin-rolle (Suksess AS intern)? */
    function isSuperAdmin() {
      return isAuthenticated() &&
        request.auth.token.get("role", "") == "superadmin";
    }

    /** Henter tenantId fra brukerens custom claim (satt av Feide OIDC) */
    function userTenantId() {
      return request.auth.token.get("tenantId", null);
    }

    /** Er brukeren en del av samme tenant? */
    function isSameTenant(tenantId) {
      return isAuthenticated() && userTenantId() == tenantId;
    }

    /**
     * Er brukeren rådgiver (counselor) i samme tenant?
     * Rådgivere har rolle "counselor" + matching tenantId claim.
     */
    function isCounselorInTenant(tenantId) {
      return isAuthenticated() &&
        request.auth.token.get("role", "") in ["counselor", "admin", "superadmin"] &&
        (userTenantId() == tenantId || isSuperAdmin());
    }

    /** Er brukeren rådgiver eller admin? */
    function isCounselorOrAdmin() {
      return isAuthenticated() &&
        request.auth.token.get("role", "") in ["counselor", "admin", "superadmin"];
    }

    /** Henter brukerens rolle */
    function userRole() {
      return request.auth.token.get("role", "student");
    }

    /**
     * Multi-tenant isolasjon: rådgiver kan kun lese elever i sin tenant.
     * Brukes for å sikre at counselor bare ser sin skoles data.
     */
    function canCounselorReadUser(userId) {
      // Hent mål-brukerens tenantId fra Firestore (resource.data)
      return isCounselorOrAdmin() &&
        (isSuperAdmin() ||
         resource.data.get("tenantId", null) == userTenantId());
    }

    // ---------------------------------------------------------------------------
    // users/{userId} — elevprofil og stamdata
    // ---------------------------------------------------------------------------

    match /users/{userId} {
      // Elever leser/skriver egne data
      // Rådgivere leser kun brukere i sin tenant (multi-tenant isolasjon)
      allow read: if isOwner(userId) || canCounselorReadUser(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) ||
        (isCounselorOrAdmin() && resource.data.get("tenantId", null) == userTenantId());
      allow delete: if isSuperAdmin();

      // Personlighetsprofil (subcollection) — sensitiv data
      match /personalityProfile/{docId} {
        allow read: if isOwner(userId) ||
          (isCounselorOrAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get("tenantId", null) == userTenantId());
        allow write: if isOwner(userId);
      }

      // Testresultater (subcollection)
      match /testResults/{resultId} {
        allow read: if isOwner(userId) ||
          (isCounselorOrAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get("tenantId", null) == userTenantId());
        allow write: if isOwner(userId);
      }

      // Karakterer (subcollection)
      match /grades/{gradeId} {
        allow read: if isOwner(userId) ||
          (isCounselorOrAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get("tenantId", null) == userTenantId());
        allow write: if isOwner(userId);
      }

      // Samtalehistorikk med AI (subcollection) — kun eleven selv
      match /conversations/{convId} {
        allow read, write: if isOwner(userId);
      }

      // Varsler (subcollection)
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) || isCounselorOrAdmin();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // Gamification (subcollection) — XP og achievements
      match /gamification/{docId} {
        allow read: if isOwner(userId) || isCounselorOrAdmin();
        allow write: if isOwner(userId);
      }

      // Achievements (subcollection)
      match /achievements/{achievId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // AI-innholdscache per bruker (subcollection)
      match /aiCache/{cacheKey} {
        allow read, write: if isOwner(userId);
      }

      // Dokumenter og testresultat-arkiv (subcollection)
      match /documents/{docId} {
        allow read: if isOwner(userId) ||
          (isCounselorOrAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get("tenantId", null) == userTenantId());
        allow write: if isOwner(userId);
      }

      // Søknader (subcollection)
      match /soknader/{soknadId} {
        allow read: if isOwner(userId) ||
          (isCounselorOrAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get("tenantId", null) == userTenantId());
        allow write: if isOwner(userId);
      }

      // Studier (subcollection) — emner og eksamenssjekkliste
      match /studier/{docId} {
        allow read, write: if isOwner(userId);
      }

      // CV-utkast (subcollection)
      match /cv/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Jobbmatch-favoritter (subcollection)
      match /jobbmatch/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Søknadscoach-data (subcollection)
      match /soknadscoach/{docId} {
        allow read, write: if isOwner(userId);
      }

      // GDPR-samtykke (subcollection) — eleven, superadmin og skoleadmin (#134)
      match /consent/{consentId} {
        allow read: if isOwner(userId) || isSuperAdmin() ||
          (isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get("tenantId", null) == userTenantId());
        allow write: if isOwner(userId);
      }
    }

    // ---------------------------------------------------------------------------
    // profiles/{userId} — offentlig(ere) profil med RIASEC/cluster
    // ---------------------------------------------------------------------------

    match /profiles/{userId} {
      allow read: if isOwner(userId) ||
        (isCounselorOrAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get("tenantId", null) == userTenantId());
      allow write: if isOwner(userId);
    }

    // ---------------------------------------------------------------------------
    // tenants/{tenantId} — skole/fylkeskommuneprofil
    // ---------------------------------------------------------------------------

    match /tenants/{tenantId} {
      // Tenant-admin leser og skriver sin tenant; superadmin kan alt
      allow read: if isSameTenant(tenantId) || isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if (isSameTenant(tenantId) && isAdmin()) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Rådgivere i denne tenanten
      match /counselors/{counselorId} {
        allow read: if isSameTenant(tenantId) || isSuperAdmin();
        allow write: if (isSameTenant(tenantId) && isAdmin()) || isSuperAdmin();
      }

      // Konfigurasjon for tenanten (chatbot-innstillinger, branding etc.)
      match /config/{configId} {
        allow read: if isSameTenant(tenantId);
        allow write: if (isSameTenant(tenantId) && isAdmin()) || isSuperAdmin();
      }

      // Aggregerte statistikker for tenanten (oppdateres av Cloud Functions)
      match /stats/{period} {
        allow read: if isCounselorInTenant(tenantId);
        allow write: if false; // kun Cloud Functions (admin SDK)
      }

      // Feide-grupper synkronisert fra Groups API (#135)
      match /groups/{groupId} {
        allow read: if isCounselorInTenant(tenantId);
        allow write: if false; // kun Cloud Functions (admin SDK)
      }

      // Rådgiver-notater om elever (tenantId-scopet, ikke under user/)
      match /counselorNotes/{noteId} {
        allow read: if isCounselorInTenant(tenantId);
        allow create: if isCounselorInTenant(tenantId) &&
          request.resource.data.tenantId == tenantId;
        allow update: if isCounselorInTenant(tenantId) &&
          resource.data.tenantId == tenantId &&
          request.auth.uid == resource.data.authorId;
        allow delete: if (isCounselorInTenant(tenantId) &&
          request.auth.uid == resource.data.authorId) || isSuperAdmin();
      }
    }

    // ---------------------------------------------------------------------------
    // schoolStats/{tenantId} — denormaliserte skolestatistikker (Cloud Functions)
    // ---------------------------------------------------------------------------

    match /schoolStats/{tenantId} {
      allow read: if isCounselorInTenant(tenantId);
      allow write: if false; // kun Cloud Functions (admin SDK)
    }

    // ---------------------------------------------------------------------------
    // consentLogs/{logId} — samtykkelogg per tenant (#134)
    // ---------------------------------------------------------------------------

    match /consentLogs/{logId} {
      allow read: if isAdmin() && resource.data.get("tenantId", null) == userTenantId();
      allow write: if false; // kun Cloud Functions (admin SDK)
    }

    // ---------------------------------------------------------------------------
    // invoices/{invoiceId} — Stripe-fakturaer speilet (#134)
    // ---------------------------------------------------------------------------

    match /invoices/{invoiceId} {
      allow read: if isAdmin() && resource.data.get("tenantId", null) == userTenantId();
      allow write: if false; // kun Cloud Functions (admin SDK)
    }

    // ---------------------------------------------------------------------------
    // careerPaths/{pathId} — delte karriereveier (read-only for brukere)
    // ---------------------------------------------------------------------------

    match /careerPaths/{pathId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // studyPrograms/{programId}
    // ---------------------------------------------------------------------------

    match /studyPrograms/{programId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // programfag/{fagId}
    // ---------------------------------------------------------------------------

    match /programfag/{fagId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // navJobs/{jobId} — NAV stillingsdatabase (ingestet av Cloud Scheduler)
    // ---------------------------------------------------------------------------

    match /navJobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if false; // kun Cloud Functions
    }

    // ---------------------------------------------------------------------------
    // semanticCache/{cacheId} — semantisk LLM-cache
    // ---------------------------------------------------------------------------

    match /semanticCache/{cacheId} {
      // Leses av server-side Cloud Functions; klienter kan lese (for edge cache)
      allow read: if isAuthenticated();
      allow write: if false; // kun Cloud Functions (admin SDK)
    }

    // ---------------------------------------------------------------------------
    // apiResponseCache/{cacheId} — API-respons cache
    // ---------------------------------------------------------------------------

    match /apiResponseCache/{cacheId} {
      allow read: if isAuthenticated();
      allow write: if false; // kun Cloud Functions
    }

    // ---------------------------------------------------------------------------
    // llmLogs/{logId} — LLM-brukslogg for kostnadsovervåking
    // ---------------------------------------------------------------------------

    match /llmLogs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false; // kun Cloud Functions
    }

    // ---------------------------------------------------------------------------
    // generatedContent/{contentId} — AI-generert innhold
    // ---------------------------------------------------------------------------

    match /generatedContent/{contentId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         resource.data.userId == null);
      allow write: if false; // kun Cloud Functions
    }

    // ---------------------------------------------------------------------------
    // subscriptions/{userId}
    // ---------------------------------------------------------------------------

    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // kun Cloud Functions (Stripe webhook)
    }

    // ---------------------------------------------------------------------------
    // apiKeys/{keyId}
    // ---------------------------------------------------------------------------

    match /apiKeys/{keyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // featureFlags/{flagId}
    // ---------------------------------------------------------------------------

    match /featureFlags/{flagId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------------------
    // notes/{noteId} — personlige notater
    // ---------------------------------------------------------------------------

    match /notes/{noteId} {
      allow read, write: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // ---------------------------------------------------------------------------
    // consentAudit/{auditId} — revisjonsspor for samtykke (immutable)
    // ---------------------------------------------------------------------------

    match /consentAudit/{auditId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // immutable audit trail
    }

    // ---------------------------------------------------------------------------
    // aiDecisionLogs/{logId} — EU AI Act Art. 12 loggføring (Issue #103)
    // ---------------------------------------------------------------------------

    match /aiDecisionLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // immutable audit trail — 5 års oppbevaring
    }

    // ---------------------------------------------------------------------------
    // humanOversightEvents/{eventId} — EU AI Act Art. 14 mennesketilsyn (#103)
    // ---------------------------------------------------------------------------

    match /humanOversightEvents/{eventId} {
      allow read: if isCounselorOrAdmin();
      allow create: if isAuthenticated();
      allow update: if isCounselorOrAdmin(); // rådgiver kan markere som gjennomgått
      allow delete: if false; // immutable
    }

    // ---------------------------------------------------------------------------
    // errorLogs/{logId} — feillogging
    // ---------------------------------------------------------------------------

    match /errorLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ---------------------------------------------------------------------------
    // chatRooms/{roomId} — rådgiver-elev sanntidschat (#108)
    // ---------------------------------------------------------------------------

    match /chatRooms/{roomId} {
      allow read: if isAuthenticated() &&
        (resource.data.studentUid == request.auth.uid ||
         resource.data.counselorUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.studentUid == request.auth.uid ||
         resource.data.counselorUid == request.auth.uid);

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          (get(/databases/$(database)/documents/chatRooms/$(roomId)).data.studentUid == request.auth.uid ||
           get(/databases/$(database)/documents/chatRooms/$(roomId)).data.counselorUid == request.auth.uid);
        allow create: if isAuthenticated() &&
          (get(/databases/$(database)/documents/chatRooms/$(roomId)).data.studentUid == request.auth.uid ||
           get(/databases/$(database)/documents/chatRooms/$(roomId)).data.counselorUid == request.auth.uid);
        allow update: if isAuthenticated() &&
          (get(/databases/$(database)/documents/chatRooms/$(roomId)).data.studentUid == request.auth.uid ||
           get(/databases/$(database)/documents/chatRooms/$(roomId)).data.counselorUid == request.auth.uid);
      }
    }

    // ---------------------------------------------------------------------------
    // parentLinks/{linkId} — foresatt-elev kobling (#106)
    // ---------------------------------------------------------------------------

    match /parentLinks/{linkId} {
      allow read: if isAuthenticated() &&
        (resource.data.parentUid == request.auth.uid || resource.data.studentUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.parentUid == request.auth.uid || resource.data.studentUid == request.auth.uid);
      allow delete: if isAuthenticated() &&
        (resource.data.parentUid == request.auth.uid || resource.data.studentUid == request.auth.uid);
    }

    // ---------------------------------------------------------------------------
    // parentInvites/{inviteId} — invitasjonskoder for foresatte (#106)
    // ---------------------------------------------------------------------------

    match /parentInvites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ---------------------------------------------------------------------------
    // parentConsentTokens/{tokenId} — samtykke-tokens for foresatte (#106)
    // Kun Cloud Functions kan lese/skrive — tokens håndteres server-side
    // ---------------------------------------------------------------------------

    match /parentConsentTokens/{tokenId} {
      allow read: if false;
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // consentAudit/{auditId} — immutabel audit-logg for foresatt-handlinger (#106)
    // Klient kan opprette (logg handling), men ikke endre/slette
    // ---------------------------------------------------------------------------

    match /consentAudit/{auditId} {
      allow read: if isAuthenticated() &&
        (resource.data.parentUid == request.auth.uid || resource.data.studentUid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if false; // Immutabel
    }

    // ---------------------------------------------------------------------------
    // emailLogs/{logId} — e-postlogg (kun Cloud Functions kan skrive)
    // ---------------------------------------------------------------------------

    match /emailLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Kun Cloud Functions via Admin SDK
    }

    // ---------------------------------------------------------------------------
    // invites/{inviteId} — skoleinvitasjoner (#111, #127)
    // ---------------------------------------------------------------------------

    match /invites/{inviteId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.email == request.auth.token.email);
      allow write: if false; // Kun Cloud Functions via Admin SDK
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profilbilder: brukere kan lese/skrive egne
    match /users/{userId}/avatar/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 && // maks 5 MB
        request.resource.contentType.matches('image/.*');
    }

    // Dokumenter og CV-eksporter: kun eieren
    match /users/{userId}/documents/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 20 * 1024 * 1024; // maks 20 MB
    }

    // Testresultater og eksporter (PDF)
    match /users/{userId}/exports/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024;
    }

    // Rådgivere kan lese studenters dokumenter (via tenantId-krav)
    match /users/{userId}/shared/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.get("role", "") in ["counselor", "admin", "superadmin"]
      );
      allow write: if request.auth != null && request.auth.uid == userId &&
        request.resource.size < 20 * 1024 * 1024;
    }

    // Alt annet er avvist
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
